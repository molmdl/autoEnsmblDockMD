integrator          =  steep
nsteps              =  50000
lincs_iter          =  8
emtol               =  100
emstep              =  0.01

constraints = h-bonds
cutoff-scheme = Verlet
vdwtype = cutoff
vdw-modifier = force-switch
rlist = 1.2
rvdw = 1.2
rvdw-switch = 1.0
coulombtype = PME
rcoulomb = 1.2
DispCorr = no

nstcomm             =  1

Tcoupl              =  no
Pcoupl              =  no
gen_vel             =  no
